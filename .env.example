# 한국전력거래소(KPX) OpenAPI — 공공데이터포털 발급 (개발단계 자동승인)
# 오늘전력수급현황 / 발전원별 발전량 서비스 활용신청 후 Decoding 키 입력
KPX_API_KEY=여기에_Decoding_키_입력

# (선택) 기상청 ASOS — 기온 보강용
WEATHER_API_KEY=

# Discord Webhook — 이상/임계 경보용 (Phase 1 후반)
DISCORD_WEBHOOK_URL=

# 데이터베이스 (변경 불필요)
DATABASE_URL=sqlite:///./src/storage/data.db

# 로깅
LOG_LEVEL=INFO
